local speedHistory          = {}
local HIST_MAX              = 30
local minSpeedSeen          = 999
local maxSpeedSeen          = 0
local currentSpeedNow       = 0
local firstSpeedReading     = nil
local ghostConfirmedBySpeed = nil   -- "Demon" | "Thaye" | nil

local function avgGradualDelta()
    if #speedHistory < 4 then return 0 end
    local totalDelta, totalTime = 0, 0
    for i = 2, #speedHistory do
        local dt = speedHistory[i].t - speedHistory[i-1].t
        local ds = speedHistory[i].s - speedHistory[i-1].s
        if dt > 0 and ds > 0 then totalDelta += ds; totalTime += dt end
    end
    if totalTime < 0.5 then return 0 end
    return totalDelta / totalTime
end

local function maxInstantJump()
    local maxJump = 0
    for i = 2, #speedHistory do
        local ds = speedHistory[i].s - speedHistory[i-1].s
        if ds > maxJump then maxJump = ds end
    end
    return maxJump
end

local function hasFallenBelow(threshold)
    return minSpeedSeen < threshold
end

-- Confirma Demon (12.4→12.5 gradual) o Thaye (13.8→13.9 gradual)
local function checkGradualStart(currentSpeed)
    if ghostConfirmedBySpeed then return ghostConfirmedBySpeed end
    local grad = avgGradualDelta()
    -- Thaye: inició en ~13.8, ya está en 13.9+ con incremento gradual
    if currentSpeed >= 13.9 and currentSpeed < 15.0 and grad >= 0.04 then
        if firstSpeedReading and firstSpeedReading.speed >= 13.4
        and firstSpeedReading.speed <= 14.2 then
            ghostConfirmedBySpeed = "Thaye"; return "Thaye"
        end
    end
    -- Demon: inició en ~12.4, ya está en 12.5+ con incremento gradual
    if firstSpeedReading then
        local base = firstSpeedReading.speed
        if base >= 12.0 and base <= 12.8 and currentSpeed >= 12.5
        and currentSpeed < 13.4 and grad >= 0.04 then
            ghostConfirmedBySpeed = "Demon"; return "Demon"
        end
    end
    return nil
end

local function speedCouldMatch(g, currentSpeed)
    local s = g.speed
    local p = s.pattern
    if currentSpeed < 11.5 then return true end
    if ghostConfirmedBySpeed then return g.name == ghostConfirmedBySpeed end

    if p == "fixed" then
        return currentSpeed >= (s.base - SPEED_TOL) and currentSpeed <= (s.base + SPEED_TOL)
    end
    if p == "preta" then
        return currentSpeed >= 15.0 and currentSpeed <= 23.5
    end
    if p == "instant_high" then
        if currentSpeed >= 20.0 then return true end
        if maxInstantJump() >= 7.0 then return true end
        return currentSpeed >= (s.base - SPEED_TOL) and currentSpeed <= (s.base + SPEED_TOL + 1.5)
    end
    if p == "instant_mid" then
        if maxInstantJump() >= 2.5 and currentSpeed >= 14.0 then return true end
        return currentSpeed >= (s.base - SPEED_TOL) and currentSpeed <= (s.base + SPEED_TOL + 1.5)
    end
    if p == "gradual" then
        return currentSpeed >= (s.base - SPEED_TOL) and currentSpeed <= (s.max + SPEED_TOL)
    end
    if p == "rev" then
        if currentSpeed >= 17.5 then return true end
        if currentSpeed >= 13.3 and currentSpeed <= 14.3 then return true end
        return currentSpeed >= (s.base - SPEED_TOL) and currentSpeed <= (s.base + SPEED_TOL)
    end
    if p == "down" then
        if hasFallenBelow(11.8) then return true end
        return currentSpeed >= 10.5 and currentSpeed <= 12.9
    end
    if p == "bogey" then
        if currentSpeed > 14.5 then return false end
        return currentSpeed >= 12.0 and currentSpeed <= 14.2
    end
    if p == "base" then
        if currentSpeed > 14.5 then return false end
        return currentSpeed >= 11.5 and currentSpeed <= 13.5
    end
    return true
end

local function speedTag(speed)
    if speed < 11.5 then return "" end
    local jump = maxInstantJump()
    local grad = avgGradualDelta()
    if ghostConfirmedBySpeed == "Demon" then return "🔴 gradual desde 12.4: DEMON confirmado" end
    if ghostConfirmedBySpeed == "Thaye" then return "🔴 gradual desde 13.8: THAYE confirmado" end
    if speed >= 22.5 then return "🔴 ~"..string.format("%.1f",speed)..": HAINT (único)" end
    if jump >= 7.0 or (speed >= 20.0 and jump >= 3.0) then return "🔴 salto >20: JINN (único)" end
    if speed >= 17.5 and speed <= 18.5 then return "🟡 ~17.9: MYLING (único)" end
    if hasFallenBelow(11.8) then return "🔵 bajó a ~11: WISP (único)" end
    if grad >= 0.06 and speed >= 14.5 then return "🟡 subiendo gradual: Demon o Thaye" end
    if jump >= 2.5 and speed >= 15.5 then return "🟠 salto inst.: Afarit/Yokai/Mare" end
    if speed >= 15.0 and speed <= 15.6 then return "🟢 ~15.1: Duppy o Wendigo" end
    if speed >= 13.9 and speed <= 14.9 then return "🟣 ~14.4: O Tokata" end
    if speed >= 13.3 and speed <= 14.3 then return "🔵 ~13.8: Blair/Afarit/Yokai/Thaye" end
    if speed >= 12.0 and speed <= 12.9 then return "⚪ ~12.4: muchos posibles" end
    return ""
end


-- ── Helpers de pickup ─────────────────────────────────────────────────────────
local function pickupWithPrompt(model)
    if not model then return false end
    local prompt = model:FindFirstChildWhichIsA("ProximityPrompt", true)
    if not prompt then return false end
    local char = player.Character or player.CharacterAdded:Wait()
    local hrp  = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    local pos = getPosition(model)
    if not pos then return false end
    hrp.CFrame = CFrame.new(pos + Vector3.new(0,3,2))
    task.wait(0.2)
    local cam = workspace.CurrentCamera
    cam.CameraType = Enum.CameraType.Scriptable
    cam.CFrame = CFrame.lookAt(cam.CFrame.Position, pos)
    task.wait(0.15)
    pcall(fireproximityprompt, prompt)
    task.wait(0.1)
    local pressKeyLocal = function(keyCode)
        VirtualInputManager:SendKeyEvent(true,  keyCode, false, game)
        task.wait(0.05)
        VirtualInputManager:SendKeyEvent(false, keyCode, false, game)
    end
    pressKeyLocal(Enum.KeyCode.F)
    cam.CameraType = Enum.CameraType.Custom
    return true
end

local function waitForDisappear(model, timeout)
    local deadline = tick() + timeout
    while tick() < deadline do
        if not model or not model.Parent then return true end
        task.wait(0.15)
    end
    return false
end

local function placeItemNearGhost(slot)
    local char = player.Character or player.CharacterAdded:Wait()
    local hrp  = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local ghostPos = getPosition(ghost)
    if not ghostPos then return end
    hrp.CFrame = CFrame.new(ghostPos + Vector3.new(3,0,3))
    task.wait(0.2)
    local cam = workspace.CurrentCamera
    cam.CameraType = Enum.CameraType.Scriptable
    cam.CFrame = CFrame.lookAt(cam.CFrame.Position, hrp.Position + Vector3.new(0,-2,0))
    task.wait(0.1)
    VirtualInputManager:SendKeyEvent(true,  slot, false, game)
    task.wait(0.05)
    VirtualInputManager:SendKeyEvent(false, slot, false, game)
    task.wait(0.3)
    local vp = workspace.CurrentCamera.ViewportSize
    VirtualInputManager:SendMouseButtonEvent(vp.X/2, vp.Y/2, 0, true,  game, 0)
    task.wait(0.08)
    VirtualInputManager:SendMouseButtonEvent(vp.X/2, vp.Y/2, 0, false, game, 0)
    cam.CameraType = Enum.CameraType.Custom
end

-- ── Rutina de inicio ──────────────────────────────────────────────────────────
local function initialPickupRoutine()
    task.spawn(function()
        task.wait(1)
        local van = workspace:WaitForChild("Van", 10)
        if not van then return end
        local vanEquip = van:FindFirstChild("Equipment")
        if not vanEquip then return end

        local book = vanEquip:FindFirstChild("Book")
        if book then pickupWithPrompt(book); waitForDisappear(book, 5) end

        local motionSensor = vanEquip:FindFirstChild("Motion Sensor")
        if motionSensor then pickupWithPrompt(motionSensor); waitForDisappear(motionSensor, 5) end

        task.wait(0.3)
        placeItemNearGhost(Enum.KeyCode.One)
        task.wait(2)
        placeItemNearGhost(Enum.KeyCode.Two)
        task.wait(10)

        -- Acercarse al ghost y mirar 3s
        local ghostPos = getPosition(ghost)
        if ghostPos then
            local char = player.Character or player.CharacterAdded:Wait()
            local hrp  = char:FindFirstChild("HumanoidRootPart")
            if hrp then
                hrp.CFrame = CFrame.new(ghostPos + Vector3.new(0,5,3))
                task.wait(0.15)
                local cam = workspace.CurrentCamera
                cam.CameraType = Enum.CameraType.Scriptable
                local lookDeadline = tick() + 3
                while tick() < lookDeadline do
                    local gp = getPosition(ghost)
                    if gp then cam.CFrame = CFrame.lookAt(cam.CFrame.Position, gp) end
                    task.wait(0.05)
                end
                cam.CameraType = Enum.CameraType.Custom
                task.wait(0.1)
            end
        end

        -- Check motion
        local ghostModel = workspace.NPCs and workspace.NPCs:FindFirstChildOfClass("Model")
        if ghostModel then
            local ghostRoot = ghostModel:FindFirstChild("HumanoidRootPart")
            if ghostRoot then
                local sg = motions:FindFirstChild("SensorGrid")
                if sg then
                    local saved = {}
                    for _, grid in pairs(sg:GetChildren()) do
                        if grid:IsA("Part") then
                            saved[grid] = grid.CFrame
                            grid.CFrame = ghostRoot.CFrame + Vector3.new(1,0,0)
                        end
                    end
                    task.wait(0.3)
                    for part, cf in pairs(saved) do part.CFrame = cf end
                end
            end
        end

        -- Collect bone + vigilar ghost
        if bone then
            local bonePos = getPosition(bone)
            if bonePos then
                local char = player.Character or player.CharacterAdded:Wait()
                local hrp  = char:FindFirstChild("HumanoidRootPart")
                if hrp then
                    hrp.CFrame = CFrame.new(bonePos + Vector3.new(0,4,0))
                    task.wait(0.2)
                    workspace.CurrentCamera.CFrame = CFrame.new(workspace.CurrentCamera.CFrame.Position, bonePos)
                    task.wait(0.2)
                    local prompt = bone:FindFirstChildWhichIsA("ProximityPrompt", true)
                    if prompt then pcall(fireproximityprompt, prompt) end
                    task.wait(0.5)
                    local watchDeadline = tick() + 15
                    while tick() < watchDeadline do
                        local gPos = getPosition(ghost)
                        local pPos = hrp and hrp.Position
                        if gPos and pPos and (gPos - pPos).Magnitude < 10 then
                            local v = workspace:FindFirstChild("Van")
                            if v and v.PrimaryPart then hrp.CFrame = v.PrimaryPart.CFrame + Vector3.new(0,5,0) end
                            break
                        end
                        task.wait(0.3)
                    end
                end
            end
        end

        -- Volver a la van
        local v  = workspace:FindFirstChild("Van")
        local sp = v and v:FindFirstChild("Spawn")
        local char = player.Character or player.CharacterAdded:Wait()
        local hrp  = char:FindFirstChild("HumanoidRootPart")
        if hrp and sp then
            local spPos = getPosition(sp)
            if spPos then hrp.CFrame = CFrame.new(spPos + Vector3.new(0,3,0)) end
        end
    end)
end


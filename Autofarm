local function countVotes(targetFrame)
    local guesses = targetFrame:FindFirstChild("Guesses")
    if not guesses then return 0 end
    local count = 0
    for _, child in ipairs(guesses:GetChildren()) do
        if not child:IsA("UIGridLayout") then count += 1 end
    end
    return count
end

-- Obtiene el centro clickeable del frame del ghost en el journal
-- Según la imagen: el frame es ImageButton con AbsolutePosition ya disponible
local function getFrameClickPos(targetFrame)
    local abs = targetFrame.AbsolutePosition
    local sz  = targetFrame.AbsoluteSize
    if abs.X > 0 and abs.Y > 0 then
        -- Usar el centro del frame directamente (no hace falta ir al Box interno)
        return abs.X + sz.X / 2, abs.Y + sz.Y / 2 + START_OFFSET_Y
    end
    return nil, nil
end

local function doTpAndHoldE(closePos)
    local char = player.Character or player.CharacterAdded:Wait()
    local hrp  = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    hrp.CFrame = CFrame.new(closePos + Vector3.new(0, 3, 3))
    task.wait(0.2)
    local cam = workspace.CurrentCamera
    cam.CameraType = Enum.CameraType.Scriptable
    cam.CFrame = CFrame.lookAt(cam.CFrame.Position, closePos)
    task.wait(0.1)
    VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.E, false, game)
    local holdDeadline = tick() + 5
    while tick() < holdDeadline do
        cam.CFrame = CFrame.lookAt(cam.CFrame.Position, closePos)
        task.wait(0.05)
    end
    VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.E, false, game)
    cam.CameraType = Enum.CameraType.Custom
end

-- ── autoSelectGhostAndSubmit ──────────────────────────────────────────────────
autoSelectGhostAndSubmit = function(ghostName)
    if autoSubmitDone then return end
    autoSubmitDone = true

    task.spawn(function()
        pressKey(Enum.KeyCode.J)

        local playerGui = player:FindFirstChild("PlayerGui")
        if not playerGui then return end

        local ghostSel
        local deadline = tick() + 8
        while tick() < deadline do
            local ok, result = pcall(function()
                return playerGui.Journal.Frame.Frame.Selection.Evidence.Right.GhostSelection
            end)
            if ok and result then ghostSel = result; break end
            task.wait(0.15)
        end
        if not ghostSel then return end

        -- Buscar el frame del ghost por nombre
        local targetFrame = nil
        for _, child in ipairs(ghostSel:GetChildren()) do
            if child.Name == ghostName then targetFrame = child; break end
        end
        if not targetFrame then return end

        -- Esperar que el frame tenga posición válida
        local posDeadline = tick() + 5
        local cx, cy
        while tick() < posDeadline do
            cx, cy = getFrameClickPos(targetFrame)
            if cx and cx > 10 and cy > 10 then break end
            -- Intentar scroll hacia el frame si no es visible
            task.wait(0.12)
        end
        if not cx or cx <= 10 then return end

        task.wait(0.4)

        -- Ciclo de voto: llevar a exactamente 1 voto
        -- Cada click alterna: 0→1→2→1→... entonces:
        -- Si votes==0: click una vez → 1 ✓
        -- Si votes==1: ya listo
        -- Si votes==2: click una vez → 1 ✓
        -- Si votes==3+: click una vez → reduce

        local MAX_TRIES = 15
        for i = 1, MAX_TRIES do
            local votes = countVotes(targetFrame)
            if votes == 1 then break end
            local ox, oy = getFrameClickPos(targetFrame)
            if ox then clickAt(ox, oy) end
            task.wait(0.5)
        end

        -- Verificación final
        if countVotes(targetFrame) ~= 1 then
            local ox, oy = getFrameClickPos(targetFrame)
            if ox then clickAt(ox, oy); task.wait(0.6) end
        end

        local van = workspace:FindFirstChild("Van")
        local vanClose = van and van:FindFirstChild("Close")
        local closePos = vanClose and getPosition(vanClose)

        pressKey(Enum.KeyCode.J)
        task.wait(0.5)

        if closePos then doTpAndHoldE(closePos) end
    end)
end


-- ══════════════════════════════════════════════════════════════
--  CÁLCULO DE CANDIDATOS — intersección speed + evidencia + trait
--  Con lógica especial para descartes cruzados:
--
--  REGLAS DE DESCARTE CRUZADO:
--  Si speed ~13.8 fija (no sube, no salta):
--    → solo Blair (nunca cambia), descarta Yokai/Afarit/Thaye
--  Si speed ~13.8 y luego saltó instantáneamente:
--    → Yokai (→16.5) o Afarit (→19.3), descarta Blair/Thaye
--  Si speed ~13.8 y subió gradual (Thaye confirmado):
--    → solo Thaye, descarta Blair/Yokai/Afarit
--  Si speed ~12.4 y subió gradual (Demon confirmado):
--    → solo Demon, descarta Rev/Wisp/Bogey/base
--  Si speed ~12.4 fija sin cambios tras 20s:
--    → descarta Rev (que siempre pasa a 13.8) y Demon/Thaye (que suben)
-- ══════════════════════════════════════════════════════════════
local function calcCandidates()
    local speedFiltering = currentSpeedNow >= 11.5

    -- ── Filtro de velocidad ───────────────────────────────────────────────────
    local speedSet = {}
    if speedFiltering then
        for _, g in ipairs(GHOSTS) do
            if speedCouldMatch(g, currentSpeedNow) then
                speedSet[g.name] = true
            end
        end
    end

    -- ── Filtro de evidencia ───────────────────────────────────────────────────
    local evSet = {}
    for _, g in ipairs(GHOSTS) do
        local ok = true
        -- rechazar si tiene evidencia descartada
        for ev in pairs(rejectedEv) do
            for _, gev in ipairs(g.ev) do
                if gev == ev then ok = false; break end
            end
            if not ok then break end
        end
        -- requerir evidencias detectadas
        if ok then
            for ev in pairs(detectedEv) do
                local has = false
                for _, gev in ipairs(g.ev) do
                    if gev == ev then has = true; break end
                end
                if not has then ok = false; break end
            end
        end
        if ok then evSet[g.name] = true end
    end

    -- ── Intersección ─────────────────────────────────────────────────────────
    local result = {}
    for _, g in ipairs(GHOSTS) do
        local passes
        if speedFiltering and anyEvidence then
            passes = speedSet[g.name] and evSet[g.name]
        elseif speedFiltering then
            passes = speedSet[g.name]
        elseif anyEvidence then
            passes = evSet[g.name]
        else
            passes = true
        end

        -- Filtro de trait
        if passes and detectedTrait then
            passes = (g.trait == detectedTrait)
        end

        if passes then table.insert(result, g.name) end
    end

    -- ══════════════════════════════════════════════════════════════
    --  DESCARTES CRUZADOS ESPECIALES
    --  Aplicar lógica adicional sobre la lista de candidatos
    -- ══════════════════════════════════════════════════════════════
    if speedFiltering and #result > 1 then
        local speed = currentSpeedNow
        local jump  = maxInstantJump()
        local grad  = avgGradualDelta()
        local elapsed = firstSpeedReading and (tick() - firstSpeedReading.time) or 0

        -- ── Blair vs Yokai/Afarit/Thaye ────────────────────────────────────
        -- Si hay Blair en candidatos: si la speed ya saltó o subió, descartamos Blair
        -- Si la speed lleva tiempo fija en ~13.8 sin saltar ni subir, descartamos Yokai/Afarit/Thaye
        local hasBlair  = false
        local hasYokai  = false
        local hasAfarit = false
        local hasThaye  = false
        local hasRev    = false
        local hasDemon  = false
        for _, n in ipairs(result) do
            if n == "Blair"    then hasBlair  = true end
            if n == "Yokai"    then hasYokai  = true end
            if n == "Afarit"   then hasAfarit = true end
            if n == "Thaye"    then hasThaye  = true end
            if n == "Revenant" then hasRev    = true end
            if n == "Demon"    then hasDemon  = true end
        end

        if hasBlair and (hasYokai or hasAfarit or hasThaye) then
            if speed >= 13.3 and speed <= 14.3 then
                if jump >= 2.5 then
                    -- Saltó: no es Blair (fijo). Descartar Blair
                    local filtered = {}
                    for _, n in ipairs(result) do
                        if n ~= "Blair" then table.insert(filtered, n) end
                    end
                    result = filtered
                elseif grad >= 0.04 and elapsed >= 3 then
                    -- Está subiendo gradual: no es Blair ni Yokai/Afarit (instantáneos)
                    local filtered = {}
                    for _, n in ipairs(result) do
                        if n ~= "Blair" and n ~= "Yokai" and n ~= "Afarit" then
                            table.insert(filtered, n)
                        end
                    end
                    result = filtered
                elseif elapsed >= 25 and jump < 0.5 and grad < 0.03 then
                    -- Lleva 25s sin moverse: es Blair. Descartar Yokai/Afarit/Thaye
                    local filtered = {}
                    for _, n in ipairs(result) do
                        if n ~= "Yokai" and n ~= "Afarit" and n ~= "Thaye" then
                            table.insert(filtered, n)
                        end
                    end
                    result = filtered
                end
            end
        end

        -- ── Revenant vs Demon/Wisp/Bogey en rango 12.4 ────────────────────
        -- Rev siempre sube a 13.8 en algún momento.
        -- Si llevamos 20s en 12.4 fijo, descartamos Rev (ya hubiera subido) y Demon/Thaye
        if hasRev and elapsed >= 20 and speed >= 12.0 and speed <= 12.9
        and jump < 0.4 and grad < 0.02 then
            local filtered = {}
            for _, n in ipairs(result) do
                if n ~= "Revenant" and n ~= "Demon" and n ~= "Thaye" then
                    table.insert(filtered, n)
                end
            end
            result = filtered
        end

        -- ── Si hay Blair + Revenant: ambos en 13.8 ────────────────────────
        -- Rev eventualmente salta a 17.9. Si speed ya está en 13.8 estable
        -- y llevamos suficiente tiempo sin subir, es Blair (Rev hubiera saltado)
        if hasBlair and hasRev and speed >= 13.3 and speed <= 14.3
        and elapsed >= 30 and jump < 0.5 then
            -- Rev llega a 17.9 al ver jugador. Si no saltó, puede ser Blair.
            -- No descartamos aún: dejamos que el tiempo/salto lo confirme.
            -- Pero si el bot ya hizo checkMotion (que acerca el fantasma), y no saltó:
            -- poner como único Blair (heurística conservadora tras 30s)
            local filtered = {}
            for _, n in ipairs(result) do
                if n ~= "Revenant" then table.insert(filtered, n) end
            end
            result = filtered
        end
    end

    return result
end

